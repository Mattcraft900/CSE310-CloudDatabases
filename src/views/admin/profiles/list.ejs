<%- include('../../partials/header', { title: 'Profiles' }) %>

<div class="page-header">
    <h2>Profiles</h2>
    <a class="button" href="/admin/profiles/new">+ New Profile</a>
</div>

<% if (message) { %>
<p class="message success"><%= message %></p>
<% } %>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category</th>
            <th>Snippet</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (profiles.length === 0) { %>
        <tr><td colspan="5">No profiles yet. Run <code>npm run seed:profiles</code> or add one.</td></tr>
        <% } %>
        <% profiles.forEach(function(p) { %>
        <tr>
            <td><%= p.id %></td>
            <td><%= p.name %></td>
            <td><%= p.category %></td>
            <td><%= p.snippet || '—' %></td>
            <td class="actions">
                <a href="/admin/profiles/<%= p.id %>/edit">Edit</a>
                <form method="POST" action="/admin/profiles/<%= p.id %>?_method=DELETE" class="inline-form"
                      onsubmit="return confirm('Delete this profile?');">
                    <button type="submit" class="link-button danger">Delete</button>
                </form>
            </td>
        </tr>
        <% }); %>
    </tbody>
</table>

<%- include('../../partials/footer') %>
