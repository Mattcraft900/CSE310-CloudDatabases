<%- include('../../partials/header', { title: isNew ? 'New Section' : 'Edit Section' }) %>

<h2><%= isNew ? 'Add Section' : 'Edit Section' %></h2>
<p><a href="/admin/travelogue/sessions/<%= sessionId %>">← Back to session</a></p>

<form method="POST" action="<%= isNew ? '/admin/travelogue/sessions/' + sessionId + '/sections' : '/admin/travelogue/sections/' + section.id + '?_method=PUT' %>" class="form-grid">
    <label>In-game date
        <input name="in_game_date" value="<%= section.in_game_date || '' %>" placeholder="7 / 13 / 568">
    </label>
    <label>Sort order <input name="sort_order" type="number" value="<%= section.sort_order ?? 0 %>"></label>

    <fieldset class="full-width">
        <legend>Paragraphs</legend>
        <p class="hint">One paragraph per blank line. Use &lt;angle brackets&gt; for Nemah's voice.</p>
        <textarea name="paragraphs" rows="16"><%= paragraphsText %></textarea>
    </fieldset>

    <div class="form-actions full-width">
        <button type="submit" class="button"><%= isNew ? 'Add Section' : 'Save' %></button>
        <a href="/admin/travelogue/sessions/<%= sessionId %>">Cancel</a>
    </div>
</form>

<%- include('../../partials/footer') %>
