<%- include('../../partials/header', { title: 'Travelogue Sessions' }) %>

<div class="page-header">
    <h2>Travelogue Sessions</h2>
    <a class="button" href="/admin/travelogue/sessions/new">+ New Session</a>
</div>

<% if (message) { %>
<p class="message success"><%= message %></p>
<% } %>

<table>
    <thead>
        <tr>
            <th>Order</th>
            <th>Session</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (sessions.length === 0) { %>
        <tr><td colspan="3">No sessions yet. Run <code>npm run seed:travelogue</code> or add one.</td></tr>
        <% } %>
        <% sessions.forEach(function(s) { %>
        <tr>
            <td><%= s.sort_order %></td>
            <td><a href="/admin/travelogue/sessions/<%= s.id %>"><%= s.label %></a></td>
            <td class="actions">
                <a href="/admin/travelogue/sessions/<%= s.id %>">View</a>
                <a href="/admin/travelogue/sessions/<%= s.id %>/edit">Edit</a>
                <form method="POST" action="/admin/travelogue/sessions/<%= s.id %>?_method=DELETE" class="inline-form"
                      onsubmit="return confirm('Delete this session and all its sections?');">
                    <button type="submit" class="link-button danger">Delete</button>
                </form>
            </td>
        </tr>
        <% }); %>
    </tbody>
</table>

<%- include('../../partials/footer') %>
