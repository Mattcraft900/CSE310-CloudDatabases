<%
function formatDate(d) {
    if (!d) return '';
    const dt = new Date(d);
    return dt.toISOString().slice(0, 10);
}
%>
<%- include('../../partials/header', { title: isNew ? 'New Session' : 'Edit Session' }) %>

<h2><%= isNew ? 'New Travelogue Session' : 'Edit Session' %></h2>

<form method="POST" action="<%= isNew ? '/admin/travelogue/sessions' : '/admin/travelogue/sessions/' + session.id + '?_method=PUT' %>" class="form-grid">
    <label>Session title <input name="session_title" value="<%= session.session_title || '' %>" required placeholder="Prologue or Saint Dane"></label>
    <label>Real session date
        <input name="real_session_date" type="date" value="<%= formatDate(session.real_session_date) %>">
    </label>
    <p class="hint full-width">Leave date empty for sessions like Prologue. Or use M.D.YY format:</p>
    <label>Real session date (M.D.YY)
        <input name="real_session_date_mdy" placeholder="6.13.26">
    </label>
    <label>Sort order <input name="sort_order" type="number" value="<%= session.sort_order ?? 0 %>"></label>

    <div class="form-actions full-width">
        <button type="submit" class="button"><%= isNew ? 'Create' : 'Save' %></button>
        <a href="<%= isNew ? '/admin/travelogue/sessions' : '/admin/travelogue/sessions/' + session.id %>">Cancel</a>
    </div>
</form>

<%- include('../../partials/footer') %>
