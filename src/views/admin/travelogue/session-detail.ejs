<%
function formatDate(d) {
    if (!d) return '';
    const dt = new Date(d);
    return dt.toISOString().slice(0, 10);
}
%>
<%- include('../../partials/header', { title: session.label }) %>

<div class="page-header">
    <h2><%= session.label %></h2>
    <div>
        <a class="button secondary" href="/admin/travelogue/sessions/<%= session.id %>/edit">Edit Session</a>
        <a class="button" href="/admin/travelogue/sessions/<%= session.id %>/sections/new">+ Add Section</a>
    </div>
</div>

<% if (message) { %>
<p class="message success"><%= message %></p>
<% } %>

<p><a href="/admin/travelogue/sessions">← All sessions</a></p>

<h3>Sections</h3>
<% if (sections.length === 0) { %>
<p>No sections in this session yet.</p>
<% } %>

<% sections.forEach(function(sec) { %>
<article class="section-card">
    <div class="section-card-header">
        <h4><%= sec.in_game_date || '(no in-game date)' %></h4>
        <div class="actions">
            <a href="/admin/travelogue/sections/<%= sec.id %>/edit">Edit</a>
            <form method="POST" action="/admin/travelogue/sections/<%= sec.id %>?_method=DELETE" class="inline-form"
                  onsubmit="return confirm('Delete this section?');">
                <button type="submit" class="link-button danger">Delete</button>
            </form>
        </div>
    </div>
    <p class="preview"><%= (sec.paragraphs && sec.paragraphs[0]) ? sec.paragraphs[0].slice(0, 120) + '…' : '(empty)' %></p>
    <p class="meta"><%= sec.paragraphs ? sec.paragraphs.length : 0 %> paragraph(s) · sort order <%= sec.sort_order %></p>
</article>
<% }); %>

<%- include('../../partials/footer') %>
